// Тест препроцессора с поддержкой #elif
#define MAX_SIZE 100
#define PI 3.14159
#define GREETING "Hello, World!"
#define DEBUG 2
#define FEATURE_ENABLED 1

#ifdef DEBUG
#else
    #define LOG(msg) // Nothing
#endif

#ifndef VERSION
    #define VERSION "1.0.0"
#endif

fn main() {
    int array[MAX_SIZE];
    float area = PI * 5 * 5;
    string message = GREETING;
    
    // Тест #ifdef
    #ifdef DEBUG
    #endif
    
    // Тест #if с числовым сравнением
    #if MAX_SIZE > 50
    #endif
    
    // Тест #if с defined()
    #if defined(PI) && defined(GREETING)
    #endif
    
    // Тест #elif
    #if DEBUG == 1
    #elif DEBUG == 2
    #elif DEBUG == 3
    #else
    #endif
    
    // Тест вложенных условий
    #if defined(MAX_SIZE)
        #if MAX_SIZE > 100
        #elif MAX_SIZE > 50
        #else
        #endif
    #endif
    
    #warning This is a test warning
    
    return 0;
}